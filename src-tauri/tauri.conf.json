{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Portex PDV",
  "version": "1.0.0",
  "identifier": "com.portex.pdv",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Portex PDV",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Gabriel Portela Carmo",
    "icon": ["icons/icon.ico"]
  }
}
